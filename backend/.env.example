# JWT Secret (required)
JWT_SECRET=

# Orígenes adicionales CORS (separados por coma, producción)
# CORS_ORIGINS=https://prueba-ceiba-frontend.onrender.com

# Keep-alive (producción Render)
KEEPALIVE_URL=
KEEPALIVE_INTERVAL_MINUTES=10
