PORT=6002

# MongoDB Connection
CLUSTER_DB_MONGO=cluster0.example.mongodb.net
NAME_CONTAINER_DB_MONGO=ceiba-mercadoexpress
USER_DB_MONGO=
PASSWORD_DB_MONGO=

# Fallback URI (local development)
